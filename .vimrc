" ~/.vimrc (symlinked from ~/dotfiles/.vimrc)
" ==============================
" Basics
" ==============================
set nocompatible
syntax on
filetype plugin indent on
set encoding=utf-8
set termguicolors

" ==============================
" Indentation
" ==============================
set tabstop=4
set shiftwidth=4
set expandtab
set softtabstop=4
set smartindent
set autoindent

" ==============================
" UI
" ==============================
set number
set relativenumber
set splitbelow
set splitright
set hlsearch
set incsearch
set smartcase
set nobackup
set nowritebackup
